# AIDEN Brain API v2 - Environment Variables

# === LLM Providers ===
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...

# Model configuration
AIDEN_MAIN_MODEL=claude-sonnet-4-20250514
AIDEN_FAST_MODEL=claude-haiku-4-5-20251001

# === Database ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Stripe (Billing) ===
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# === Server ===
PORT=3000
NODE_ENV=production

# === Auth ===
API_KEY_SALT=random-salt-for-hashing
ADMIN_SECRET=a-strong-random-secret-for-admin-endpoints

# === Rate Limiting ===
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_DAY=10000

# === CORS ===
ALLOWED_ORIGINS=https://your-frontend.com,https://app.yourdomain.com
